package  com.loop;
import java.util.Random;
import java.util.Scanner;

public class PigDiceGame {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Random random = new Random();

        int totalScore = 0;
        int turn = 1;
        final int TARGET = 20;

        System.out.println("Let's Play PIG!");
        System.out.println("See how many turns it takes you to get to " + TARGET + ".");
        System.out.println("Turn ends when you hold or roll a 1.");
        System.out.println("If you roll a 1, you lose all points for the turn.");
        System.out.println("If you hold, you save all points for the turn.");
        System.out.println();

        while (totalScore < TARGET) {
            int turnScore = 0;
            System.out.println("TURN " + turn);

            while (true) {
                System.out.print("Roll or hold? (r/h): ");
                String choice = scanner.next().toLowerCase();

                if (choice.equals("r")) {
                    int die = random.nextInt(6) + 1; // 1 to 6
                    System.out.println("Die: " + die);

                    if (die == 1) {
                        System.out.println("Turn over. No score.");
                        turnScore = 0;
                        break;
                    } else {
                        turnScore += die;
                    }
                } 
                else if (choice.equals("h")) {
                    totalScore += turnScore;
                    System.out.println("Score for turn: " + turnScore);
                    System.out.println("Total score: " + totalScore);
                    break;
                } 
                else {
                    System.out.println("Invalid input. Please enter 'r' or 'h'.");
                }
            }

            System.out.println();
            turn++;
        }

        System.out.println("You finished in " + (turn - 1) + " turns!");
        System.out.println("Game over!");
        scanner.close();
    }
}
