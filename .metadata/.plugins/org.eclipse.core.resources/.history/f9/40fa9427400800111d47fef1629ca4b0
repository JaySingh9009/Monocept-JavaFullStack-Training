package com.loop;

import java.util.Scanner;

public class Digitsum {
	public static void main(String[] args) {
		
		Scanner scanner=new Scanner(System.in);
		System.out.println("Enter a valid integer to get sum of its digit: ");
		int integer=Math.abs(scanner.nextInt());
		
		System.out.println("Digit sum by for loop");
		int digitsum=0;
		for(int i=integer;i>0;i=i/10) {
			int lastdigit=i%10;
			digitsum=digitsum+lastdigit;
			
		}
		System.out.println("Digit sum is: " +digitsum);
		
//		using while loop
		System.out.println("Digit sum by for while");
		int newdigitsum=0;
		
		int copyOfinteger=integer;
		while(copyOfinteger>0) {
			int lastdigit=copyOfinteger%10;
			newdigitsum+=lastdigit;
			copyOfinteger=copyOfinteger/10;
			
			
		}
		System.out.println("Digit sum is: "+ newdigitsum);
		
		
		
	}

}
