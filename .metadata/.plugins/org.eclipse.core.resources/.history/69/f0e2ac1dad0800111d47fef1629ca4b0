package com.BasicArray;
import java.util.*;

public class SecondMaxOfArray {
	public static void main(String[] args) {
		Scanner scanner=new Scanner(System.in);
		System.out.println("Enter the valid size of Array: ");
		int size=scanner.nextInt();
		if(size>0) {
			int[] array=new int[size];
			System.out.println("Enter array elements :");
			for(int i=0;i<size;i++) {
				array[i]=scanner.nextInt();
			}
			
			int max = Integer.MIN_VALUE;
			int secondMax = Integer.MIN_VALUE;
			if(size>1) {
			for (int i = 0; i < size; i++) {
			    if (array[i] > max) {
			        secondMax = max;     
			        max = array[i];
			    } 
			    else if (array[i] < max && array[i] > secondMax) {
			        secondMax = array[i];
			    }
			}
			}
			else {
				System.out.println("size must be greater than 2");;
			}
			System.out.println("Maximum of array is: "+ max + " And Second Maximum is: "+secondMax);
			
		}else {
			System.out.println("Enter a valid positive size");
		}
	}
	

}
